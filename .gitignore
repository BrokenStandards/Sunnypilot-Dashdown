# --- Reference clones -------------------------------------------------------
# Third-party source kept for reading only. Huge, never committed, and
# reconstructable via `tools/fetch-refs.sh` (pinned SHAs in docs/REFERENCES.md).
# Gitignoring also keeps ref/ out of ripgrep / Grep tool results by default.
/ref/

# --- Rust -------------------------------------------------------------------
/target
**/*.rs.bk
*.pdb

# --- Generated UniFFI bindings (regenerated by the bindgen crate) -----------
/bindings-generated/

# --- Android ----------------------------------------------------------------
/android/.gradle
/android/.kotlin
/android/**/build/
/android/local.properties
/android/.idea
/android/captures
# cargo-ndk drops cross-compiled .so here; rebuilt every Gradle build.
/android/core/src/main/jniLibs/

# --- iOS / Swift ------------------------------------------------------------
.build/
*.xcframework/
/ios/.swiftpm
DerivedData/

# --- Env / secrets ----------------------------------------------------------
.env
*.local

# --- OS / editor ------------------------------------------------------------
.DS_Store
*.swp

# Claude Code transient runtime lock
.claude/scheduled_tasks.lock
